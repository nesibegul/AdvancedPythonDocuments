    "# Cell 4: SQLAlchemy Schema and Database Export\n",
    "from sqlalchemy import create_engine, Column, Integer, String, Float\n",
    "from sqlalchemy.orm import declarative_base\n",
    "\n",
    "# Define Database Metadata Model\n",
    "Base = declarative_base()\n",
    "\n",
    "class NaceStatistic(Base):\n",
    "    __tablename__ = 'nace_statistics'\n",
    "    \n",
    "    id = Column(Integer, primary_key=True, autoincrement=True)\n",
    "    nace_r2 = Column(String, index=True) # Index configured to optimize queries by economic segment\n",
    "    geo = Column(String, index=True)\n",
    "    time = Column(String)\n",
    "    unit = Column(String)\n",
    "    value = Column(Float)\n",
    "\n",
    "# Connect via SQLAlchemy connection engine to prevent transaction drops\n",
    "DB_URI = 'sqlite:///eurostat_nace.db'\n",
    "engine = create_engine(DB_URI)\n",
    "\n",
    "Base.metadata.create_all(engine)\n",
    "\n",
    "# Load to Local DB Storage \n",
    "try:\n",
    "    # Passing active Engine connection instead of raw target URI path string to prevent database thread crashes\n",
    "    df_nace.write_database(\n",
    "        table_name=\"nace_statistics\", \n",
    "        connection=engine, \n",
    "        if_table_exists=\"replace\"\n",
    "    )\n",
    "    print(\"✅ Structured analytical dataset saved to SQLite database: eurostat_nace.db\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Database Persistence Failure: {e}\")"
   ]
