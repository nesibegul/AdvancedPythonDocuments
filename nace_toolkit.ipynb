    "# Cell 2: Eurostat API Client Implementation\n",
    "\n",
    "class EurostatClient:\n",
    "    \"\"\"Client for fetching NACE statistical data from the Eurostat API.\"\"\"\n",
    "    \n",
    "    BASE_URL = \"https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data\"\n",
    "\n",
    "    def __init__(self, timeout: int = 30):\n",
    "        self.timeout = timeout\n",
    "\n",
    "    def fetch_dataset(self, dataset_code: str, params: dict = None) -> dict:\n",
    "        \"\"\"\n",
    "        Performs a GET request to the Eurostat API for a specific dataset.\n",
    "        \n",
    "        :param dataset_code: The dataset identifier (e.g., 'nama_10_a64')\n",
    "        :param params: Optional filtering parameters (format, geo, time, etc.)\n",
    "        :return: JSON response as a dictionary\n",
    "        \"\"\"\n",
    "        # Enforce JSON format output\n",
    "        default_params = {\"format\": \"JSON\", \"lang\": \"en\"}\n",
    "        if params:\n",
    "            default_params.update(params)\n",
    "\n",
    "        url = f\"{self.BASE_URL}/{dataset_code}\"\n",
    "        logger.info(f\"Starting data download from URL: {url}\")\n",
    "        \n",
    "        try:\n",
    "            response = requests.get(url, params=default_params, timeout=self.timeout)\n",
    "            response.raise_for_status()\n",
    "            logger.info(f\"✅ Download Completed: {dataset_code}\")\n",
    "            return response.json()\n",
    "        except requests.exceptions.RequestException as e:\n",
    "            logger.error(f\"❌ Eurostat API Connection Error: {e}\")\n",
    "            raise\n",
    "\n",
    "# Test Client\n",
    "client = EurostatClient()"
   ]
