    "# Cell 3: Parsing & Dataset Extraction\n",
    "import time\n",
    "import itertools\n",
    "import polars as pl\n",
    "\n",
    "def parse_eurostat_json_to_polars(json_data):\n",
    "    \"\"\"Transform Eurostat JSON-stat format to a Polars DataFrame.\"\"\"\n",
    "    dimensions = json_data.get('id', [])\n",
    "    dim_categories = [\n",
    "        list(json_data['dimension'][d]['category']['index'].keys()) \n",
    "        for d in dimensions\n",
    "    ]\n",
    "    cartesian_product = list(itertools.product(*dim_categories))\n",
    "    values = json_data.get('value', {})\n",
    "    \n",
    "    records = []\n",
    "    for i, combo in enumerate(cartesian_product):\n",
    "        val = values.get(str(i), None)\n",
    "        record = {dimensions[j]: combo[j] for j in range(len(dimensions))}\n",
    "        record['value'] = val\n",
    "        records.append(record)\n",
    "        \n",
    "    df = pl.DataFrame(records)\n",
    "    # Clean data structure and cast metrics to Float64\n",
    "    df_clean = (\n",
    "        df.with_columns(pl.col('value').cast(pl.Float64))\n",
    "        .drop_nulls(subset=['value'])\n",
    "    )\n",
    "    return df_clean\n",
    "\n",
    "\n",
    "DATASET_CODE = \"nama_10_a10\"\n",
    "\n",
    "# Target Countries List\n",
    "target_countries = [\"TR\", \"EL\", \"DE\", \"FR\", \"IT\", \"ES\", \"CY\", \"NL\", \"BE\", \"DK\", \"SE\", \"MD\", \"AT\", \"CH\", \"XK\", \"BA\", \"RS\"]\n",
    "\n",
    "all_dfs = []\n",
    "print(f\"🚀 Starting chunked batch download for {len(target_countries)} regions...\")\n",
    "\n",
    "for country in target_countries:\n",
    "    try:\n",
    "        # Filter API request scope per country code\n",
    "        params = {\n",
    "            \"format\": \"JSON\", \n",
    "            \"lang\": \"en\", \n",
    "            \"geo\": country,\n",
    "            \"unit\": \"CP_MEUR\",   # Current prices, million euros\n",
    "            \"na_item\": \"B1G\"     # Gross value added\n",
    "        }\n",
    "        raw_data = client.fetch_dataset(DATASET_CODE, params=params)\n",
    "        \n",
    "        # Convert API responses into structured Polars records\n",
    "        df_temp = parse_eurostat_json_to_polars(raw_data)\n",
    "        all_dfs.append(df_temp)\n",
    "        \n",
    "        # 1-second delay to prevent hitting API rate limits\n",
    "        time.sleep(1)\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"⚠️ Error downloading data for region {country}: {e}\")\n",
    "\n",
    "# Consolidate chunked DataFrames\n",
    "if all_dfs:\n",
    "    df_nace = pl.concat(all_dfs)\n",
    "    print(f\"\\n✅ Extraction Pipeline Completed Successfully!\")\n",
    "    print(f\"📊 Total compiled DataFrame contains {len(df_nace)} rows.\")\n",
    "    print(f\"🌍 Monitored Regions: {sorted(df_nace['geo'].unique().to_list())}\")\n",
    "    print(f\"📅 Temporary Scope (Years): {sorted(df_nace['time'].unique().to_list())}\")\n",
    "else:\n",
    "    print(\"\\n❌ Execution Failure: No pipeline matrices captured.\")"
   ]
